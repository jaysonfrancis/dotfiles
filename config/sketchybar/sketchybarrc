PLUGIN_DIR="$CONFIG_DIR/plugins"

# Tokyo Night color palette
BAR_BG=0x00000000        # transparent bar
ITEM_BG=0xf01a1b26        # item pill background
ICON_COLOR=0xff7aa2f7     # blue
LABEL_COLOR=0xffc0caf5    # foreground
ACCENT=0xff7aa2f7         # blue accent
HIGHLIGHT=0xffbb9af7      # purple
GREEN=0xff9ece6a
RED=0xfff7768e
YELLOW=0xffe0af68
CYAN=0xff7dcfff
SUBTLE=0xff565f89         # muted text

sketchybar --bar position=top height=40 blur_radius=0 color=$BAR_BG topmost=window

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="Hack Nerd Font:Bold:14.0"
  icon.color=$ICON_COLOR
  label.color=$LABEL_COLOR
  icon.padding_left=8
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=8
  background.color=$ITEM_BG
  background.corner_radius=8
  background.height=28
  background.drawing=on
)
sketchybar --default "${default[@]}"

##### AeroSpace Workspace Indicators #####
sketchybar --add event aerospace_workspace_change

WORKSPACES=("1" "2" "3" "4" "5" "6")
for sid in "${WORKSPACES[@]}"
do
  sketchybar --add item space."$sid" left \
             --subscribe space."$sid" aerospace_workspace_change \
             --set space."$sid" \
             icon="$sid" \
             icon.color=$SUBTLE \
             icon.padding_left=10 \
             icon.padding_right=10 \
             background.color=$ITEM_BG \
             background.corner_radius=8 \
             background.height=28 \
             label.drawing=off \
             script="$PLUGIN_DIR/aerospace.sh" \
             click_script="aerospace workspace $sid"
done

##### Left Items #####
sketchybar --add item front_app left \
           --set front_app icon.drawing=off \
                           label.color=$LABEL_COLOR \
                           background.color=$ITEM_BG \
                           script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Right Items #####
sketchybar --add item music right \
           --set music update_freq=5 \
                         icon=󰎆 \
                         icon.color=$RED \
                         icon.font="Hack Nerd Font:Bold:22.0" \
                         label.color=$LABEL_COLOR \
                         label.drawing=off \
                         script="$PLUGIN_DIR/music.sh" \
                         click_script="osascript -e 'tell application \"Music\" to playpause'" \
           --add item music.next right \
           --set music.next \
                         icon=󰒭 \
                         icon.font="Hack Nerd Font:Bold:20.0" \
                         icon.color=$RED \
                         label.drawing=off \
                         drawing=off \
                         click_script="osascript -e 'tell application \"Music\" to next track'" \
           --add item clock right \
           --set clock update_freq=10 \
                       icon= \
                       icon.color=$YELLOW \
                       label.color=$LABEL_COLOR \
                       script="$PLUGIN_DIR/clock.sh" \
--add item volume right \
           --set volume icon.color=$GREEN \
                        label.color=$LABEL_COLOR \
                        script="$PLUGIN_DIR/volume.sh" \
                        click_script="$PLUGIN_DIR/volume_click.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 \
                         icon.color=$ACCENT \
                         label.color=$LABEL_COLOR \
                         script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --update
